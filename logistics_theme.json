{
  "name": "Logistics Analytics - Teal & Red",
  "dataColors": [
    "#0F6E6E",
    "#B91C1C",
    "#6B7280",
    "#134E4A",
    "#9CA3AF",
    "#1F2937",
    "#E5E7EB",
    "#374151"
  ],
  "background": "#FFFFFF",
  "foreground": "#111827",
  "tableAccent": "#0F6E6E",
  "good": "#0F6E6E",
  "neutral": "#6B7280",
  "bad": "#B91C1C",
  "maximum": "#0F6E6E",
  "center": "#9CA3AF",
  "minimum": "#B91C1C",
  "null": "#E5E7EB",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#111827"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#111827"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#374151"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 32,
      "color": "#0F6E6E"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "alignment": "left",
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#0F6E6E"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#374151"
              }
            },
            "fontSize": 10,
            "showAxisTitle": false,
            "gridlineColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 10,
            "showAxisTitle": false,
            "gridlineColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ],
        "labels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#0F6E6E"
              }
            }
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 3,
            "showMarker": true,
            "markerSize": 5
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#374151"
              }
            },
            "fontSize": 10,
            "showAxisTitle": false
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 10,
            "showAxisTitle": false,
            "gridlineColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0F6E6E"
              }
            },
            "fontSize": 32,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#6B7280"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 6
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F3F4F6"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ],
        "total": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F3F4F6"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F9FAFB"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}
